# docker-compose environment variables
# Copy this to .env and fill in values — never commit .env

DB_USER=helpit
DB_PASSWORD=replace-with-strong-password
DB_NAME=helpit

JWT_SECRET=replace-with-64-char-random-string

# Your production frontend URL (used for backend CORS)
CORS_ORIGIN=https://your-domain.com

# Host port to expose the app on
PORT=80

# Microsoft 365 SMTP — email notifications (STARTTLS on port 587)
# Leave blank to disable email notifications (app runs fine without these)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=no-reply@your-domain.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_NAME=helpIT Notifications
SMTP_FROM_ADDRESS=no-reply@your-domain.com
