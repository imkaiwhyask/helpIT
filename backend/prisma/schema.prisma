generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("user")
  department    String   @default("")
  phone         String   @default("")
  is_active            Boolean  @default(true)
  failed_login_count   Int      @default(0)
  locked_until         DateTime? @db.Timestamptz
  must_change_password Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz

  assigned_tickets  Ticket[]          @relation("AssignedTo")
  created_tickets   Ticket[]          @relation("CreatedBy")
  comments          TicketComment[]
  attachments       TicketAttachment[]
  kb_articles       KbArticle[]

  @@map("users")
}

model Ticket {
  id                    Int       @id @default(autoincrement())
  title                 String
  description           String    @default("")
  category              String    @default("Other")
  subcategory           String    @default("")
  priority              String    @default("medium")
  status                String    @default("open")
  assigned_to           Int?
  created_by            Int
  created_at            DateTime  @default(now()) @db.Timestamptz
  updated_at            DateTime  @default(now()) @db.Timestamptz
  resolved_at           DateTime? @db.Timestamptz
  response_due          DateTime  @db.Timestamptz
  resolution_due        DateTime  @db.Timestamptz
  first_response_at     DateTime? @db.Timestamptz
  sla_response_breached   Boolean @default(false)
  sla_resolution_breached Boolean @default(false)

  assigned_user User?             @relation("AssignedTo", fields: [assigned_to], references: [id], onDelete: SetNull)
  creator       User              @relation("CreatedBy", fields: [created_by], references: [id])
  comments      TicketComment[]
  attachments   TicketAttachment[]

  @@index([created_by])
  @@index([assigned_to])
  @@index([status])
  @@index([created_at])
  @@map("tickets")
}

model TicketComment {
  id          Int      @id @default(autoincrement())
  ticket_id   Int
  user_id     Int
  content     String
  is_internal Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz

  ticket Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id])

  @@index([ticket_id])
  @@index([user_id])
  @@map("ticket_comments")
}

model TicketAttachment {
  id            Int      @id @default(autoincrement())
  ticket_id     Int
  filename      String
  original_name String
  size          Int      @default(0)
  mimetype      String   @default("")
  uploaded_by   Int?
  created_at    DateTime @default(now()) @db.Timestamptz

  ticket   Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  uploader User?  @relation(fields: [uploaded_by], references: [id], onDelete: SetNull)

  @@index([ticket_id])
  @@map("ticket_attachments")
}

model KbArticle {
  id           Int      @id @default(autoincrement())
  title        String
  content      String   @default("")
  category     String   @default("General")
  tags         String   @default("")
  author_id    Int?
  is_published Boolean  @default(true)
  view_count   Int      @default(0)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @db.Timestamptz

  author User? @relation(fields: [author_id], references: [id], onDelete: SetNull)

  @@index([author_id])
  @@index([is_published])
  @@index([category])
  @@map("kb_articles")
}
